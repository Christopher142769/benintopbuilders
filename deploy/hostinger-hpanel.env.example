# Variables à saisir dans hPanel → Node.js Web App → Environment Variables
# (ne pas committer de vraies valeurs — copier ce modèle dans l'interface Hostinger)

NODE_ENV=production
PORT=3000

# Domaine public
CLIENT_URL=https://benintopbuilders.com
CORS_ORIGINS=https://benintopbuilders.com,https://www.benintopbuilders.com

# MongoDB en ligne (Atlas, Hostinger MongoDB, etc.)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/benin-top-builders?retryWrites=true&w=majority

# Secrets (générer avec : bash deploy/generate-secrets.sh)
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=30d

# Build Vite (obligatoire AVANT le build — même origine que le domaine)
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_APP_NAME=Bénin Top Builders

# E-mail (laisser SMTP_USER vide = OTP affiché à l'écran en démo)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Bénin Top Builders <noreply@benintopbuilders.com>"

# Paiement FSPay (laisser FSPAY_BASE_URL vide = sandbox)
FSPAY_BASE_URL=
FSPAY_API_KEY=
FSPAY_WEBHOOK_SECRET=CHANGE_ME_fspay_webhook_secret
FSPAY_CALLBACK_URL=https://benintopbuilders.com/paiement/retour

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# Premier superadmin (utilisé une fois avec node src/jobs/seed.js)
SEED_SUPERADMIN_EMAIL=superadmin@benintopbuilders.com
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_StrongPassword1!
