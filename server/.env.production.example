# Serveur — référence production (utilisé surtout hors Docker)
# Sur Hostinger VPS, préférer le fichier .env à la racine du monorepo
# (chargé par docker-compose.prod.yml).

NODE_ENV=production
PORT=5001
CLIENT_URL=https://benintopbuilders.bj
CORS_ORIGINS=https://benintopbuilders.bj,https://www.benintopbuilders.bj

MONGODB_URI=mongodb://mongo:27017/benin-top-builders

JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES=30d

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Bénin Top Builders <noreply@benintopbuilders.bj>"

FSPAY_BASE_URL=
FSPAY_API_KEY=
FSPAY_WEBHOOK_SECRET=CHANGE_ME_fspay_webhook_secret
FSPAY_CALLBACK_URL=https://benintopbuilders.bj/paiement/retour

UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

SEED_SUPERADMIN_EMAIL=superadmin@benintopbuilders.bj
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_StrongPassword1!
