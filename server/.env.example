# --- Serveur ---
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173
# Origines CORS autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173

# --- MongoDB ---
# Exemple local : mongodb://127.0.0.1:27017/benin-top-builders
MONGODB_URI=mongodb://127.0.0.1:27017/benin-top-builders

# --- JWT ---
# Access token court (15 min). Secret long et aléatoire en production.
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
# Refresh token httpOnly (30 jours)
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES=30d

# --- SMTP (Nodemailer) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Bénin Top Builders <noreply@benintopbuilders.bj>"

# --- FSPay ---
# Si FSPAY_BASE_URL est absent → mode sandbox (succès simulé en ~2s)
FSPAY_BASE_URL=
FSPAY_API_KEY=
FSPAY_WEBHOOK_SECRET=change-me-fspay-webhook-secret
FSPAY_CALLBACK_URL=http://localhost:5173/paiement/retour

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=5

# --- Superadmin (seed) ---
SEED_SUPERADMIN_EMAIL=superadmin@benintopbuilders.bj
SEED_SUPERADMIN_PASSWORD=ChangeMeSuperAdmin1!
