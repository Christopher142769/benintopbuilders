# =============================================================================
# Bénin Top Builders — variables Docker / VPS Hostinger
# Copier vers .env à la racine :  cp .env.example .env
# =============================================================================

# Domaine public (sans slash final) — remplacer par votre domaine Hostinger
DOMAIN=benintopbuilders.bj
PUBLIC_URL=https://benintopbuilders.bj

# Ports exposés sur le VPS (Caddy écoute 80/443 ; l’app Docker reste interne)
APP_HTTP_PORT=8080

# --- API ---
NODE_ENV=production
PORT=5001
CLIENT_URL=https://benintopbuilders.bj
CORS_ORIGINS=https://benintopbuilders.bj,https://www.benintopbuilders.bj

# MongoDB (réseau Docker interne uniquement — ne pas exposer 27017)
MONGODB_URI=mongodb://mongo:27017/benin-top-builders

# JWT — générer avec : openssl rand -base64 48
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_min_32_chars_xxxxxxxxxxxx
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars_xxxxxxxxxxx
JWT_REFRESH_EXPIRES=30d

# Superadmin (seed une seule fois)
SEED_SUPERADMIN_EMAIL=superadmin@benintopbuilders.bj
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_StrongPassword1!

# SMTP Hostinger (ou autre)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Bénin Top Builders <noreply@benintopbuilders.bj>"

# FSPay (laisser FSPAY_BASE_URL vide = sandbox)
FSPAY_BASE_URL=
FSPAY_API_KEY=
FSPAY_WEBHOOK_SECRET=CHANGE_ME_fspay_webhook_secret
FSPAY_CALLBACK_URL=https://benintopbuilders.bj/paiement/retour

# Uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

# Client Vite (build Docker — même origine via Nginx)
VITE_API_URL=/api
VITE_SOCKET_URL=
VITE_APP_NAME=Bénin Top Builders
